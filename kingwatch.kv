#:import StatCard ui.widgets.StatCard

RootWidget:

<RootWidget>:
    orientation: "vertical"
    padding: "10dp"
    spacing: "10dp"

    canvas.before:
        Color:
            rgba: root.bg
        Rectangle:
            pos: self.pos
            size: self.size

    ScrollView:

        GridLayout:
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: "10dp"

            StatCard:
                id: cpu_card
                title: "CPU"

            StatCard:
                id: ram_card
                title: "RAM"

            StatCard:
                id: storage_card
                title: "Storage"

            StatCard:
                id: battery_card
                title: "Battery"

            StatCard:
                id: network_card
                title: "Network"
                show_bar: False

            StatCard:
                id: thermal_card
                title: "Thermal"

            StatCard:
                id: fps_card
                title: "FPS"