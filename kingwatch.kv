<Dashboard>:

    orientation: "vertical"
    padding: 20
    spacing: 20

    Label:
        id: cpu_label
        text: "CPU"
        font_size: 30

    Label:
        id: ram_label
        text: "RAM"
        font_size: 30

    Label:
        id: net_label
        text: "NETWORK"
        font_size: 24

    Label:
        id: battery_label
        text: "BATTERY"
        font_size: 24

    Label:
        id: temp_label
        text: "TEMP"
        font_size: 24
