#:import ArcGauge ui.widgets.ArcGauge
#:import dp kivy.metrics.dp

# ── StatCard ───────────────────────────────────────────────────────────────
<StatCard>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height
    padding: [dp(12), dp(8), dp(12), dp(8)]
    spacing: dp(4)

    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14)]

    # Card title
    Label:
        size_hint_y: None
        height: dp(18)
        text: root.title.upper()
        font_size: dp(10)
        bold: True
        color: root.title_color
        halign: "left"
        valign: "middle"
        text_size: self.size

    # Arc + Info row
    BoxLayout:
        size_hint_y: None
        height: dp(100)
        spacing: dp(10)

        ArcGauge:
            size_hint_x: None
            width: dp(100)
            size_hint_y: 1
            pct:        root.bar_pct
            arc_bg:     root.bar_bg
            label_text: root.value
            auto_color: root.auto_color
            thickness:  dp(10)

        BoxLayout:
            orientation: "vertical"
            spacing: dp(6)
            padding: [0, dp(10), dp(4), dp(10)]

            Label:
                text: root.subtitle
                font_size: dp(14)
                bold: True
                color: root.sub_color
                halign: "left"
                valign: "middle"
                text_size: self.size
                size_hint_y: 1
                shorten: True
                shorten_from: "right"

            Label:
                size_hint_y: None
                height: dp(16) if root.detail1 else 0
                opacity: 1 if root.detail1 else 0
                text: root.detail1
                font_size: dp(11)
                color: root.detail_color
                halign: "left"
                valign: "middle"
                text_size: self.size
                shorten: True
                shorten_from: "right"


# ── RootWidget ─────────────────────────────────────────────────────────────
<RootWidget>:
    orientation: "vertical"

    canvas.before:
        Color:
            rgba: root.bg
        Rectangle:
            pos:  self.pos
            size: self.size

    BoxLayout:
        size_hint_y: None
        height: dp(52)
        padding: [dp(12), dp(8)]
        spacing: dp(8)

        canvas.before:
            Color:
                rgba: root.card_bg
            Rectangle:
                pos:  self.pos
                size: self.size

        Label:
            text: "KingWatch Pro"
            font_size: dp(13)
            bold: True
            color: root.text_col
            halign: "left"
            valign: "middle"
            text_size: self.size
            size_hint_x: None
            width: dp(110)

        Label:
            text: root.clock_str
            font_size: dp(20)
            bold: True
            color: root.accent
            halign: "center"
            valign: "middle"
            text_size: self.size
            size_hint_x: 1

        Button:
            text: "Theme"
            size_hint: None, None
            size: dp(60), dp(36)
            font_size: dp(12)
            background_color: root.accent
            color: 0, 0, 0, 1
            on_release: root.cycle_theme()

        Button:
            text: "^" if root.collapsed else "v"
            size_hint: None, None
            size: dp(34), dp(36)
            font_size: dp(15)
            bold: True
            background_color: root.dim_col
            color: root.text_col
            on_release: root.toggle_collapse()

    ScrollView:
        opacity:     0 if root.collapsed else 1
        size_hint_y: 0 if root.collapsed else 1
        do_scroll_x: False

        GridLayout:
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(8)
            padding: [dp(8), dp(8), dp(8), dp(8)]

            StatCard:
                id: fps_card
                title:       "FPS / GPU"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  True

            StatCard:
                id: cpu_card
                title:       "CPU"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  True

            StatCard:
                id: ram_card
                title:       "RAM"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  True

            StatCard:
                id: battery_card
                title:       "BATTERY"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  False
                bar_color:   root.accent

            StatCard:
                id: network_card
                title:       "NETWORK"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  False
                bar_color:   root.accent

            StatCard:
                id: storage_card
                title:       "STORAGE"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  True

            StatCard:
                id: thermal_card
                title:       "THERMAL"
                bg_color:    root.card_bg
                title_color: root.dim_col
                bar_bg:      root.bar_bg
                sub_color:   root.text_col
                detail_color: root.sub_col
                auto_color:  True