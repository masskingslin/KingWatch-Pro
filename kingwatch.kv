RootWidget:

<InfoCard>:
    orientation: "horizontal"
    size_hint_y: None
    height: "40dp"

    Label:
        text: root.title
        size_hint_x: 0.6

    Label:
        text: root.value
        size_hint_x: 0.4


<RootWidget>:
    orientation: "vertical"
    padding: 20
    spacing: 20

    Label:
        text: "KingWatch Pro"
        font_size: "30sp"
        bold: True

    InfoCard:
        id: cpu_widget
        title: "CPU Monitor"

    InfoCard:
        id: ram_widget
        title: "RAM Monitor"

    InfoCard:
        id: battery_widget
        title: "Battery Monitor"

    InfoCard:
        id: network_widget
        title: "Network Monitor"

    InfoCard:
        id: storage_widget
        title: "Storage Monitor"

    InfoCard:
        id: temp_widget
        title: "Thermal Monitor"

    Button:
        text: "Refresh"
        size_hint_y: None
        height: "50dp"
        on_press: root.update_stats()