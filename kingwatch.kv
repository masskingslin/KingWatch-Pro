#:import C kivy.utils.get_color_from_hex


<StatCard>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height
    padding: [16, 12, 16, 12]
    spacing: 3

    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [14]

    Label:
        text: root.title
        color: root.title_color
        font_size: "11sp"
        halign: "left"
        valign: "middle"
        text_size: self.size
        size_hint_y: None
        height: "16dp"

    BoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: "42dp"

        Label:
            text: root.value
            color: root.value_color
            font_size: "30sp"
            bold: True
            halign: "left"
            valign: "bottom"
            text_size: self.size
            size_hint_x: 0.65

        Label:
            text: root.subtitle
            color: root.sub_color
            font_size: "12sp"
            halign: "right"
            valign: "bottom"
            text_size: self.size
            size_hint_x: 0.35

    Widget:
        size_hint_y: None
        height: "6dp" if root.show_bar else "0dp"
        opacity: 1 if root.show_bar else 0

        canvas.before:
            Color:
                rgba: root.bar_bg
            RoundedRectangle:
                pos: self.pos
                size: self.width, self.height
                radius: [3]
        canvas:
            Color:
                rgba: root.bar_color
            RoundedRectangle:
                pos: self.pos
                size: max(root.bar_pct / 100.0, 0.0) * self.width, self.height
                radius: [3]

    Label:
        text: root.detail1
        color: root.detail_color
        font_size: "11sp"
        halign: "left"
        valign: "middle"
        text_size: self.size
        size_hint_y: None
        height: "17dp" if root.detail1 else "0dp"
        opacity: 1 if root.detail1 else 0

    Label:
        text: root.detail2
        color: root.detail_color
        font_size: "11sp"
        halign: "left"
        valign: "middle"
        text_size: self.size
        size_hint_y: None
        height: "17dp" if root.detail2 else "0dp"
        opacity: 1 if root.detail2 else 0


<ThemeChip>:
    size_hint_x: None
    width: "88dp"
    size_hint_y: None
    height: "30dp"

    canvas.before:
        Color:
            rgba: root.chip_bg
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [15]
        Color:
            rgba: root.chip_border
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 14
            width: 1.4

    Label:
        text: root.label
        color: root.chip_text
        font_size: "11sp"
        bold: root.selected
        halign: "center"
        valign: "middle"
        text_size: self.size


<RootWidget>:
    orientation: "vertical"
    spacing: 0
    padding: 0

    canvas.before:
        Color:
            rgba: root.bg
        Rectangle:
            pos: self.pos
            size: self.size

    Widget:
        size_hint_y: None
        height: "36dp"

    BoxLayout:
        size_hint_y: None
        height: "48dp"
        padding: [16, 0]

        Label:
            text: "KingWatch Pro"
            font_size: "22sp"
            bold: True
            color: root.accent
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            size_hint_x: None
            width: "60dp"
            padding: [0, 16]
            spacing: 4

            Widget:
                size_hint_x: None
                width: "8dp"
                canvas:
                    Color:
                        rgba: C("#FF1744")
                    Ellipse:
                        pos: self.x, self.center_y - 4
                        size: 8, 8

            Label:
                text: "LIVE"
                font_size: "11sp"
                bold: True
                color: C("#FF1744")
                halign: "left"
                valign: "middle"
                text_size: self.size

    Label:
        text: "THEME"
        font_size: "10sp"
        color: root.dim
        size_hint_y: None
        height: "14dp"
        padding: [16, 0]
        halign: "left"
        valign: "middle"
        text_size: self.size

    ScrollView:
        do_scroll_x: True
        do_scroll_y: False
        size_hint_y: None
        height: "38dp"
        bar_width: 0

        BoxLayout:
            id: chips_row
            orientation: "horizontal"
            size_hint_x: None
            width: self.minimum_width
            spacing: 8
            padding: [16, 4, 16, 4]

    Widget:
        size_hint_y: None
        height: "1dp"
        canvas:
            Color:
                rgba: root.div
            Rectangle:
                pos: self.pos
                size: self.width, 1

    ScrollView:
        do_scroll_x: False
        do_scroll_y: True
        bar_width: "3dp"
        bar_color: root.accent
        bar_inactive_color: root.dim

        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height
            padding: [12, 12, 12, 12]
            spacing: 10

            StatCard:
                id: cpu_card
                title: "CPU USAGE"
                show_bar: True
                bg_color: root.card
                title_color: root.dim
                value_color: root.accent
                sub_color: root.dim
                bar_bg: root.card2
                detail_color: root.dim

            StatCard:
                id: ram_card
                title: "RAM"
                show_bar: True
                bg_color: root.card
                title_color: root.dim
                value_color: root.accent
                sub_color: root.dim
                bar_bg: root.card2
                detail_color: root.dim

            StatCard:
                id: storage_card
                title: "STORAGE"
                show_bar: True
                bg_color: root.card
                title_color: root.dim
                value_color: root.accent
                sub_color: root.dim
                bar_bg: root.card2
                detail_color: root.dim

            StatCard:
                id: battery_card
                title: "BATTERY"
                show_bar: True
                bg_color: root.card
                title_color: root.dim
                value_color: root.accent
                sub_color: root.dim
                bar_bg: root.card2
                detail_color: root.dim

            StatCard:
                id: network_card
                title: "NETWORK"
                bg_color: root.card
                title_color: root.dim
                value_color: root.accent
                sub_color: root.dim
                bar_bg: root.card2
                detail_color: root.dim

            StatCard:
                id: thermal_card
                title: "THERMAL"
                show_bar: True
                bg_color: root.card
                title_color: root.dim
                value_color: root.accent
                sub_color: root.dim
                bar_bg: root.card2
                detail_color: root.dim