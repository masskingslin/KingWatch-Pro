#:import StatCard ui.widgets.StatCard

RootWidget:

<RootWidget>:
    orientation: "vertical"
    padding: "10dp"
    spacing: "10dp"

    canvas.before:
        Color:
            rgba: root.bg
        Rectangle:
            pos: self.pos
            size: self.size

    ScrollView:

        GridLayout:
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: "10dp"

            StatCard:
                id: cpu_card
                title: "CPU"
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim
                bar_bg: root.card2

            StatCard:
                id: ram_card
                title: "RAM"
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim
                bar_bg: root.card2

            StatCard:
                id: storage_card
                title: "Storage"
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim
                bar_bg: root.card2

            StatCard:
                id: battery_card
                title: "Battery"
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim
                bar_bg: root.card2

            StatCard:
                id: network_card
                title: "Network"
                show_bar: False
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim

            StatCard:
                id: thermal_card
                title: "Thermal"
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim
                bar_bg: root.card2

            StatCard:
                id: fps_card
                title: "FPS"
                bg_color: root.card
                value_color: root.accent
                title_color: root.dim
                bar_bg: root.card2